<%
    const pageData = marketOpsVendorApplicationsPageData || {}
    const vendorDetail = pageData.vendorDetail || {}
    const vendorBusiness = vendorDetail.vendorBusiness || {}
    const opportunityCards = Array.isArray(pageData.opportunityCards) ? pageData.opportunityCards : []
    const applicationSummaries = Array.isArray(pageData.applicationSummaries) ? pageData.applicationSummaries : []
    const vendorApprovalStatus = vendorBusiness.approvalStatus || 'pending'
    const approvalStatusBadgeClass =
        vendorApprovalStatus === 'approved'
            ? 'text-bg-success'
            : vendorApprovalStatus === 'rejected'
              ? 'text-bg-danger'
              : 'text-bg-secondary'
%>

<div class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-4">
    <div>
        <a class="text-decoration-none small d-inline-block mb-2" href="/vendors/<%= vendorBusiness.slug %>/manage">Back to Vendor Business</a>
        <h1 class="h3 mb-2"><%= vendorBusiness.businessName || 'Vendor Applications' %></h1>
        <p class="text-body-secondary mb-0">
            Create and manage one market-group application per vendor business.
        </p>
    </div>
</div>

<%- await include('../../partials/market-ops-flash.ejs', { marketOpsFlash: pageData.flash }) %>

<section class="mb-4">
    <% if (!pageData.isApplicationCreationAvailable) { %>
        <div class="alert alert-warning mb-0">
            Applications are locked until this vendor business is approved. You can still edit the business profile while review is pending.
        </div>
    <% } %>
</section>

<section class="mb-4">
    <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
        <h2 class="h5 mb-0">Market Group Opportunities</h2>
        <span class="small text-body-secondary"><%= opportunityCards.length %> available group<%= opportunityCards.length === 1 ? '' : 's' %></span>
    </div>
    <div class="row g-3">
        <% if (opportunityCards.length === 0) { %>
            <div class="col-12">
                <div class="card">
                    <div class="card-body text-body-secondary">
                        No public market groups are available yet.
                    </div>
                </div>
            </div>
        <% } %>
        <% opportunityCards.forEach((opportunity) => { %>
            <div class="col-12 col-xxl-8">
                <div class="card h-100">
                    <div class="card-body d-flex flex-column gap-3">
                        <div class="d-flex align-items-center justify-content-between gap-3">
                            <div>
                                <h3 class="h5 mb-1"><%= opportunity.groupName %></h3>
                                <p class="text-body-secondary mb-0"><%= opportunity.summary %></p>
                            </div>
                            <div class="text-end small text-body-secondary">
                                <div><%= opportunity.feeModeLabel %></div>
                                <div><%= opportunity.feeTotalLabel %></div>
                            </div>
                        </div>
                        <div class="small text-body-secondary">
                            <%= opportunity.marketCount %> market<%= opportunity.marketCount === 1 ? '' : 's' %> in this group
                        </div>
                        <% if (opportunity.application) { %>
                            <div class="d-flex align-items-center justify-content-between gap-3">
                                <span class="badge text-bg-light border text-uppercase"><%= opportunity.application.status %></span>
                                <a class="btn btn-outline-primary btn-sm" href="/vendors/<%= vendorBusiness.slug %>/manage/applications/<%= opportunity.application.vendorApplicationId %>">
                                    Open Application
                                </a>
                            </div>
                        <% } else if (pageData.isApplicationCreationAvailable) { %>
                            <form action="/vendors/<%= vendorBusiness.slug %>/manage/applications" method="post" class="d-flex justify-content-end">
                                <input type="hidden" name="_csrf" value="<%= ws_req.csrfToken %>" />
                                <input type="hidden" name="marketGroupId" value="<%= opportunity.marketGroupId %>" />
                                <button class="btn btn-primary btn-sm" type="submit">Start Application</button>
                            </form>
                        <% } %>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</section>

<section>
    <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
        <h2 class="h5 mb-0">Current Applications</h2>
        <span class="small text-body-secondary"><%= applicationSummaries.length %> application<%= applicationSummaries.length === 1 ? '' : 's' %></span>
    </div>
    <div class="row g-3">
        <% if (applicationSummaries.length === 0) { %>
            <div class="col-12">
                <div class="card">
                    <div class="card-body text-body-secondary">
                        No applications have been created for this vendor business yet.
                    </div>
                </div>
            </div>
        <% } %>
        <% applicationSummaries.forEach((applicationSummary) => { %>
            <div class="col-12 col-xxl-8">
                <a class="card text-decoration-none text-reset h-100" href="/vendors/<%= vendorBusiness.slug %>/manage/applications/<%= applicationSummary.vendorApplicationId %>">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between gap-3 mb-2">
                            <h3 class="h5 mb-0"><%= applicationSummary.marketGroupName %></h3>
                            <span class="badge text-bg-light border text-uppercase"><%= applicationSummary.status %></span>
                        </div>
                        <div class="row g-2 small text-body-secondary">
                            <div class="col-sm-6">Selections: <%= applicationSummary.selectionCount %></div>
                            <div class="col-sm-6">Fee: <%= applicationSummary.feeTotalLabel %></div>
                            <div class="col-sm-6">Requested: <%= applicationSummary.requestedCount %></div>
                            <div class="col-sm-6">Approved: <%= applicationSummary.approvedCount %></div>
                            <% if (applicationSummary.paymentRecord) { %>
                                <div class="col-12">
                                    Payment record #<%= applicationSummary.paymentRecord.paymentRecordId %> is <strong><%= applicationSummary.paymentRecord.statusCode %></strong>.
                                </div>
                            <% } %>
                        </div>
                    </div>
                </a>
            </div>
        <% }) %>
    </div>
</section>
