<%
    const pageData = marketOpsNewVendorsPageData || {}
    const formValues = pageData.formValues || {}
    const categoryOptions = Array.isArray(pageData.categoryOptions) ? pageData.categoryOptions : []
    const ownedBusinesses = Array.isArray(pageData.ownedBusinesses) ? pageData.ownedBusinesses : []
%>

<link rel="stylesheet" href="/plugin-assets/ws_plugin_market_ops/styles/market-ops.css" />
<script src="/plugin-assets/ws_plugin_market_ops/scripts/new-vendors.js" defer></script>

<div class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 mb-2">New Vendors</h1>
        <p class="text-body-secondary mb-0">
            Start by creating your business profile. After it is approved, you can apply to upcoming markets from the same place.
        </p>
    </div>
    <a class="btn btn-outline-secondary" href="/vendors">View Approved Vendors</a>
</div>

<%- await include('../../partials/market-ops-flash.ejs', { marketOpsFlash: pageData.flash }) %>

<section class="row g-4">
    <div class="col-12 col-xxl-7">
        <div class="card">
            <div class="card-header">
                <h2 class="h5 mb-0">How this works</h2>
            </div>
            <div class="card-body">
                <ol class="mb-0 ps-3">
                    <li>Fill out your business profile with the basics about what you sell.</li>
                    <li>The market owner will review it and let you know if anything needs to be fixed.</li>
                    <li>Once your business is approved, you can apply to markets online.</li>
                </ol>
            </div>
        </div>

        <% if (ownedBusinesses.length > 0) { %>
            <section class="mt-4">
                <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
                    <h2 class="h5 mb-0">Your Vendor Businesses</h2>
                    <span class="small text-body-secondary"><%= ownedBusinesses.length %> linked profile<%= ownedBusinesses.length === 1 ? '' : 's' %></span>
                </div>
                <div class="row g-3">
                    <% ownedBusinesses.forEach((detail) => { %>
                        <%
                            const vendorApprovalStatus = detail.vendorBusiness.approvalStatus || 'pending'
                            const approvalStatusBadgeClass =
                                vendorApprovalStatus === 'approved'
                                    ? 'text-bg-success'
                                    : vendorApprovalStatus === 'rejected'
                                      ? 'text-bg-danger'
                                      : 'text-bg-secondary'
                        %>
                        <div class="col-12">
                            <a class="card text-decoration-none text-reset h-100" href="/vendors/<%= detail.vendorBusiness.slug %>/manage">
                                <div class="card-body">
                                    <div class="d-flex align-items-center justify-content-between gap-3 mb-2">
                                        <h3 class="h5 mb-0"><%= detail.vendorBusiness.businessName %></h3>
                                        <span class="badge <%= approvalStatusBadgeClass %> text-uppercase"><%= vendorApprovalStatus %></span>
                                    </div>
                                    <p class="text-body-secondary mb-0">
                                        <%= detail.vendorBusiness.summary || 'Open this business to update the profile and check its approval status.' %>
                                    </p>
                                </div>
                            </a>
                        </div>
                    <% }) %>
                </div>
            </section>
        <% } %>
    </div>

    <div class="col-12 col-xxl-5">
        <% if (!pageData.isAuthenticated) { %>
            <div class="card border-primary-subtle">
                <div class="card-body">
                    <h2 class="h5 mb-2">Sign in to get started</h2>
                    <p class="text-body-secondary mb-3">
                        You can look around without signing in, but you need an account before you can create and manage a vendor business.
                    </p>
                    <a class="btn btn-primary" href="/auth/login">Sign In</a>
                </div>
            </div>
        <% } else { %>
            <div class="card">
                <div class="card-header">
                    <h2 class="h5 mb-0">Create Your Vendor Business</h2>
                </div>
                <div class="card-body">
                    <form action="<%= pageData.formAction %>" method="post" class="row g-3">
                        <input type="hidden" name="_csrf" value="<%= ws_req.csrfToken %>" />
                        <input type="hidden" name="slug" value="<%= formValues.slug || '' %>" />
                        <div class="col-12">
                            <label class="form-label" for="vendor-business-name">Business Name</label>
                            <input id="vendor-business-name" class="form-control" type="text" name="businessName" value="<%= formValues.businessName || '' %>" maxlength="255" required />
                            <div class="form-text">This is the public name shoppers will see.</div>
                        </div>
                        <div class="col-12 pt-2">
                            <div class="small fw-semibold text-uppercase text-body-secondary">Optional Details</div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="vendor-legal-name">Legal Name</label>
                            <input id="vendor-legal-name" class="form-control" type="text" name="legalName" value="<%= formValues.legalName || '' %>" maxlength="255" />
                            <div class="form-text">Use your registered business or LLC name if it is different from your public business name.</div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="vendor-email">Public Email</label>
                            <input id="vendor-email" class="form-control" type="email" name="email" value="<%= formValues.email || '' %>" maxlength="255" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="vendor-phone">Public Phone Number</label>
                            <input id="vendor-phone" class="form-control" type="text" name="phone" value="<%= formValues.phone || '' %>" maxlength="64" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="vendor-website">Website URL</label>
                            <input id="vendor-website" class="form-control" type="text" name="websiteUrl" value="<%= formValues.websiteUrl || '' %>" maxlength="255" />
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="vendor-summary">Tag Line</label>
                            <textarea id="vendor-summary" class="form-control" rows="2" name="summary"><%= formValues.summary || '' %></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="vendor-description">Description</label>
                            <textarea id="vendor-description" class="form-control" rows="5" name="description"><%= formValues.description || '' %></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label mb-2">Product Categories</label>
                            <% if (categoryOptions.length === 0) { %>
                                <div class="text-body-secondary small border rounded p-3">
                                    No product categories are available yet. You can still create your business now and add categories later.
                                </div>
                            <% } else { %>
                                <div class="border rounded p-3">
                                    <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3">
                                        <div>
                                            <div class="small text-body-secondary" data-new-vendors-category-summary>
                                                No categories selected yet.
                                            </div>
                                            <div class="form-text mb-0">
                                                Choose the categories that best match what you sell. You can change these later.
                                            </div>
                                        </div>
                                        <button
                                            class="btn btn-outline-primary"
                                            type="button"
                                            data-bs-toggle="modal"
                                            data-bs-target="#new-vendors-category-modal"
                                        >
                                            Choose Categories
                                        </button>
                                    </div>
                                </div>

                                <div
                                    id="new-vendors-category-modal"
                                    class="modal fade"
                                    tabindex="-1"
                                    aria-labelledby="new-vendors-category-modal-title"
                                    aria-hidden="true"
                                >
                                    <div class="modal-dialog modal-lg modal-dialog-scrollable">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h2 id="new-vendors-category-modal-title" class="modal-title fs-5">Choose Product Categories</h2>
                                                <button
                                                    type="button"
                                                    class="btn-close"
                                                    data-bs-dismiss="modal"
                                                    aria-label="Close"
                                                ></button>
                                            </div>
                                            <div class="modal-body">
                                                <p class="text-body-secondary small mb-3">
                                                    Pick any categories that fit your business. You can update these later from your manage page.
                                                </p>
                                                <div class="market-ops-vendor-directory-category-grid market-ops-vendor-directory-category-grid-modal">
                                                    <% categoryOptions.forEach((category) => { %>
                                                        <label class="market-ops-vendor-directory-category-option">
                                                            <input
                                                                class="form-check-input mt-0"
                                                                type="checkbox"
                                                                name="productCategoryIds"
                                                                value="<%= category.vendorProductCategoryId %>"
                                                                data-new-vendors-category
                                                                data-new-vendors-category-label="<%= category.label %>"
                                                                <%= category.isSelected ? 'checked' : '' %>
                                                            />
                                                            <span class="d-flex flex-column gap-1">
                                                                <span class="fw-semibold"><%= category.label %></span>
                                                                <% if (category.description) { %>
                                                                    <span class="small text-body-secondary"><%= category.description %></span>
                                                                <% } %>
                                                            </span>
                                                        </label>
                                                    <% }) %>
                                                </div>
                                            </div>
                                            <div class="modal-footer justify-content-between">
                                                <button
                                                    class="btn btn-outline-secondary"
                                                    type="button"
                                                    data-new-vendors-category-clear
                                                >
                                                    Clear Categories
                                                </button>
                                                <button
                                                    class="btn btn-primary"
                                                    type="button"
                                                    data-bs-dismiss="modal"
                                                >
                                                    Done
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                        <div class="col-12">
                            <button class="btn btn-primary" type="submit">Create My Vendor Business</button>
                        </div>
                    </form>
                </div>
            </div>
        <% } %>
    </div>
</section>
