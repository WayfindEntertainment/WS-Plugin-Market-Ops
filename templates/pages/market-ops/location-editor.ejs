<%
    const editor = marketOpsLocationEditor || {}
    const formValues = editor.formValues || {}
    const location = editor.location || null
    const mode = editor.mode || 'create'
    const pageTitle = mode === 'create' ? 'Create Location' : (location?.locationName || 'Edit Location')
%>

<div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
    <div>
        <a class="text-decoration-none small d-inline-block mb-2" href="/market-ops/locations">Back to Locations</a>
        <h1 class="h3 m-0"><%= pageTitle %></h1>
        <p class="text-body-secondary mb-0">
            Capture the reusable venue details that future markets can point at.
        </p>
    </div>
</div>

<%- await include('../../partials/market-ops-flash.ejs', { marketOpsFlash: editor.flash }) %>

<section class="row">
    <div class="col-12 col-xxl-8">
        <div class="card">
            <div class="card-header">
                <h2 class="h5 mb-1">Location Details</h2>
                <p class="text-body-secondary small mb-0">Keep the canonical location record clean so each market can inherit it confidently.</p>
            </div>
            <div class="card-body">
                <form action="<%= editor.formAction %>" method="post" class="row g-3">
                    <input type="hidden" name="_csrf" value="<%= ws_req.csrfToken %>" />
                    <div class="col-12 col-md-6">
                        <label class="form-label" for="location-name">Location Name</label>
                        <input id="location-name" class="form-control" type="text" name="locationName" value="<%= formValues.locationName || '' %>" required />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label" for="location-slug">Slug</label>
                        <input id="location-slug" class="form-control" type="text" name="slug" value="<%= formValues.slug || '' %>" required />
                    </div>
                    <div class="col-12">
                        <label class="form-label" for="location-address-line-1">Address Line 1</label>
                        <input id="location-address-line-1" class="form-control" type="text" name="addressLine1" value="<%= formValues.addressLine1 || '' %>" />
                    </div>
                    <div class="col-12">
                        <label class="form-label" for="location-address-line-2">Address Line 2</label>
                        <input id="location-address-line-2" class="form-control" type="text" name="addressLine2" value="<%= formValues.addressLine2 || '' %>" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label" for="location-city">City</label>
                        <input id="location-city" class="form-control" type="text" name="city" value="<%= formValues.city || '' %>" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label" for="location-state-code">State</label>
                        <input id="location-state-code" class="form-control" type="text" name="stateCode" value="<%= formValues.stateCode || '' %>" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label" for="location-postal-code">Postal Code</label>
                        <input id="location-postal-code" class="form-control" type="text" name="postalCode" value="<%= formValues.postalCode || '' %>" />
                    </div>
                    <div class="col-12">
                        <label class="form-label" for="location-public-notes">Public Notes</label>
                        <textarea id="location-public-notes" class="form-control" rows="4" name="publicNotes"><%= formValues.publicNotes || '' %></textarea>
                    </div>
                    <div class="col-12">
                        <button class="btn btn-primary" type="submit">
                            <%= mode === 'create' ? 'Create Location' : 'Save Location' %>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
