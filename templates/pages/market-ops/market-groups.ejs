<%
    const pageData = marketOpsMarketGroupsPageData || { marketGroupCards: [] }
%>

<div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 m-0">Market Groups</h1>
        <p class="text-body-secondary mb-0">
            Organize markets by season, campaign, or operating batch before scheduling the
            individual dates.
        </p>
    </div>
    <a class="btn btn-primary" href="/market-ops/market-groups/create">New Market Group</a>
</div>

<%- await include('../../partials/market-ops-flash.ejs', { marketOpsFlash }) %>

<section class="card">
    <div class="card-header">
        <h2 class="h5 mb-1">Markets</h2>
        <p class="text-body-secondary mb-0">
            Build the parent seasonal groups first, then attach the individual market dates inside
            each one.
        </p>
    </div>
    <div class="card-body">
        <% if (pageData.marketGroupCards.length === 0) { %>
            <div class="admin-plugins-discover-empty-card">
                <div class="admin-plugins-discover-empty-card-icon">
                    <i class="bi-calendar-week" aria-hidden="true"></i>
                </div>
                <div>
                    <h3 class="h5 mb-1">No market groups yet</h3>
                    <p class="text-body-secondary mb-3">
                        Start with the parent season or operating batch before creating individual
                        markets.
                    </p>
                    <a class="btn btn-primary" href="/market-ops/market-groups/create">
                        Create First Market Group
                    </a>
                </div>
            </div>
        <% } else { %>
            <div class="row g-3">
                <% for (const card of pageData.marketGroupCards) { %>
                    <div class="col-12 col-xxl-8">
                        <a
                            class="admin-plugins-discover-plugin-card-link text-decoration-none"
                            href="/market-ops/market-groups/<%= card.marketGroup.marketGroupId %>"
                        >
                            <article class="admin-plugins-discover-plugin-card h-100">
                                <div class="admin-plugins-discover-plugin-card-header">
                                    <div class="admin-plugins-discover-plugin-card-icon">
                                        <i class="bi-calendar-week" aria-hidden="true"></i>
                                    </div>
                                    <div class="d-flex flex-wrap align-items-center gap-2">
                                        <h3 class="h5 mb-0 admin-plugins-discover-plugin-card-title">
                                            <%= card.marketGroup.groupName %>
                                        </h3>
                                        <span class="badge text-bg-light">
                                            <%= card.marketCount %> market<%= card.marketCount === 1 ? '' : 's' %>
                                        </span>
                                        <span class="badge <%= card.marketGroup.isPublic === 1 ? 'text-bg-success' : 'text-bg-secondary' %>">
                                            <%= card.visibilityLabel %>
                                        </span>
                                    </div>
                                </div>

                                <p class="mb-3 text-body-secondary">
                                    <%= card.marketGroup.summary || card.marketGroup.description || 'Open the group to add public copy, fee configuration, and individual market dates.' %>
                                </p>

                                <div class="d-flex flex-column gap-1 small text-body-secondary">
                                    <div><strong class="text-body-emphasis">Fee Model:</strong> <%= card.feePresentation.modeLabel %></div>
                                    <div><strong class="text-body-emphasis">Application Fee:</strong> <%= card.feePresentation.feeSummary %></div>
                                </div>
                            </article>
                        </a>
                    </div>
                <% } %>
            </div>
        <% } %>
    </div>
</section>
