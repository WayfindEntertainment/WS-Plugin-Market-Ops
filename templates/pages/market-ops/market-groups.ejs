<%
    const pageData = marketOpsMarketGroupsPageData || { marketGroupCards: [] }
%>

<div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 m-0">Market Groups</h1>
        <p class="text-body-secondary mb-0">Organize markets by season, campaign, or operating batch before scheduling the individual dates.</p>
    </div>
    <a class="btn btn-primary" href="/market-ops/market-groups/create">New Market Group</a>
</div>

<%- await include('../../partials/market-ops-flash.ejs', { marketOpsFlash }) %>

<section class="row g-3">
    <% if (pageData.marketGroupCards.length === 0) { %>
        <div class="col-12">
            <div class="card">
                <div class="card-body text-body-secondary">
                    No market groups yet. Start with the parent season or cohort before creating individual markets.
                </div>
            </div>
        </div>
    <% } %>

    <% for (const card of pageData.marketGroupCards) { %>
        <div class="col-12 col-xl-6">
            <a class="card h-100 text-decoration-none text-reset" href="/market-ops/market-groups/<%= card.marketGroup.marketGroupId %>">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                        <div>
                            <h2 class="h5 mb-1"><%= card.marketGroup.groupName %></h2>
                            <p class="text-body-secondary small mb-0"><%= card.marketGroup.slug %></p>
                        </div>
                        <span class="badge text-bg-light"><%= card.marketCount %> market<%= card.marketCount === 1 ? '' : 's' %></span>
                    </div>
                    <p class="mb-2"><%= card.marketGroup.summary || 'No short summary recorded yet.' %></p>
                    <div class="small text-body-secondary">
                        Fee mode: <%= card.marketGroup.feeMode %>
                        <% if (card.marketGroup.feeAmountCents > 0) { %>
                            · $<%= (card.marketGroup.feeAmountCents / 100).toFixed(2) %>
                        <% } %>
                    </div>
                </div>
            </a>
        </div>
    <% } %>
</section>
