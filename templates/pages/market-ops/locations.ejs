<%
    const pageData = marketOpsLocationsPageData || { locations: [] }
%>

<div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 m-0">Locations</h1>
        <p class="text-body-secondary mb-0">Manage the places where individual markets can be scheduled.</p>
    </div>
    <a class="btn btn-primary" href="/market-ops/locations/create">New Location</a>
</div>

<%- await include('../../partials/market-ops-flash.ejs', { marketOpsFlash }) %>

<section class="row g-3">
    <% if (pageData.locations.length === 0) { %>
        <div class="col-12">
            <div class="card">
                <div class="card-body text-body-secondary">
                    No locations yet. Add the first indoor or outdoor venue before building markets.
                </div>
            </div>
        </div>
    <% } %>

    <% for (const location of pageData.locations) { %>
        <div class="col-12 col-lg-6 col-xl-4">
            <a class="card h-100 text-decoration-none text-reset" href="/market-ops/locations/<%= location.locationId %>">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <h2 class="h5 mb-1"><%= location.locationName %></h2>
                            <p class="text-body-secondary small mb-2"><%= location.slug %></p>
                        </div>
                    </div>
                    <p class="mb-1"><%= location.addressLine1 || 'No primary street address recorded yet.' %></p>
                    <p class="text-body-secondary small mb-0">
                        <%= [location.city, location.stateCode, location.postalCode].filter(Boolean).join(', ') || 'City, state, and postal code not recorded yet.' %>
                    </p>
                </div>
            </a>
        </div>
    <% } %>
</section>
