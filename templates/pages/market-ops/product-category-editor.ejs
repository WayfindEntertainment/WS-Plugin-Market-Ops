<%
    const editor = marketOpsVendorProductCategoryEditor || {}
    const formValues = editor.formValues || {}
    const vendorProductCategory = editor.vendorProductCategory || null
    const mode = editor.mode || 'create'
    const pageTitle =
        mode === 'create'
            ? 'Create Product Category'
            : (vendorProductCategory?.label || 'Edit Product Category')
    const helpers = editor.helpers || {}
    const isChecked = typeof helpers.isCheckedValue === 'function' ? helpers.isCheckedValue : (() => false)
%>

<div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
    <div>
        <a class="text-decoration-none small d-inline-block mb-2" href="/market-ops/setup?section=product_categories">Back to Product Categories</a>
        <h1 class="h3 m-0"><%= pageTitle %></h1>
        <p class="text-body-secondary mb-0">
            Manage the reusable category records vendors can use across many markets.
        </p>
    </div>
</div>

<%- await include('../../partials/market-ops-flash.ejs', { marketOpsFlash: editor.flash }) %>

<section class="row">
    <div class="col-12 col-xxl-8">
        <div class="card">
            <div class="card-header">
                <h2 class="h5 mb-1">Product Category Details</h2>
                <p class="text-body-secondary small mb-0">
                    Keep the category library clear and reusable so vendors can describe their businesses consistently.
                </p>
            </div>
            <div class="card-body">
                <form action="<%= editor.formAction %>" method="post" class="row g-3">
                    <input type="hidden" name="_csrf" value="<%= ws_req.csrfToken %>" />
                    <div class="col-12 col-md-6">
                        <label class="form-label" for="product-category-label">Label</label>
                        <input id="product-category-label" class="form-control" type="text" name="label" value="<%= formValues.label || '' %>" maxlength="255" required />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label" for="product-category-slug">Slug</label>
                        <input id="product-category-slug" class="form-control" type="text" name="slug" value="<%= formValues.slug || '' %>" maxlength="128" required />
                    </div>
                    <div class="col-12">
                        <label class="form-label" for="product-category-description">Description</label>
                        <textarea id="product-category-description" class="form-control" rows="4" name="description"><%= formValues.description || '' %></textarea>
                    </div>
                    <div class="col-12 d-flex align-items-end">
                        <div class="form-check mb-2">
                            <input
                                id="product-category-is-active"
                                class="form-check-input"
                                type="checkbox"
                                name="isActive"
                                value="1"
                                <%= isChecked(formValues.isActive) ? 'checked' : '' %>
                            />
                            <label class="form-check-label" for="product-category-is-active">
                                Active and available for vendor profiles
                            </label>
                        </div>
                    </div>
                    <div class="col-12">
                        <button class="btn btn-primary" type="submit">
                            <%= mode === 'create' ? 'Create Product Category' : 'Save Product Category' %>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<script src="/plugin-assets/ws_plugin_market_ops/scripts/product-category-editor.js"></script>
