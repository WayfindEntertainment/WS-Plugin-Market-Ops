<%
    const editor = marketOpsBoothTypeEditor || {}
    const formValues = editor.formValues || {}
    const boothType = editor.boothType || null
    const mode = editor.mode || 'create'
    const pageTitle = mode === 'create' ? 'Create Booth Type' : (boothType?.label || 'Edit Booth Type')
    const helpers = editor.helpers || {}
    const isChecked = typeof helpers.isCheckedValue === 'function' ? helpers.isCheckedValue : (() => false)
%>

<div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
    <div>
        <a class="text-decoration-none small d-inline-block mb-2" href="/market-ops/setup?section=booth_types">Back to Booth Types</a>
        <h1 class="h3 m-0"><%= pageTitle %></h1>
        <p class="text-body-secondary mb-0">
            Manage the reusable booth formats markets can later offer and assign.
        </p>
    </div>
</div>

<%- await include('../../partials/market-ops-flash.ejs', { marketOpsFlash: editor.flash }) %>

<section class="row">
    <div class="col-12 col-xxl-8">
        <div class="card">
            <div class="card-header">
                <h2 class="h5 mb-1">Booth Type Details</h2>
                <p class="text-body-secondary small mb-0">
                    Keep the canonical booth-type record clean so markets can reuse it confidently.
                </p>
            </div>
            <div class="card-body">
                <form action="<%= editor.formAction %>" method="post" class="row g-3">
                    <input type="hidden" name="_csrf" value="<%= ws_req.csrfToken %>" />
                    <div class="col-12 col-md-6">
                        <label class="form-label" for="booth-type-label">Label</label>
                        <input id="booth-type-label" class="form-control" type="text" name="label" value="<%= formValues.label || '' %>" maxlength="255" required />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label" for="booth-type-slug">Slug</label>
                        <input id="booth-type-slug" class="form-control" type="text" name="slug" value="<%= formValues.slug || '' %>" maxlength="128" required />
                    </div>
                    <div class="col-12">
                        <label class="form-label" for="booth-type-description">Description</label>
                        <textarea id="booth-type-description" class="form-control" rows="4" name="description"><%= formValues.description || '' %></textarea>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label" for="booth-type-sort-order">Sort Order</label>
                        <input
                            id="booth-type-sort-order"
                            class="form-control"
                            type="number"
                            min="0"
                            name="sortOrder"
                            value="<%= formValues.sortOrder || '0' %>"
                            required
                        />
                    </div>
                    <div class="col-12 col-md-6 d-flex align-items-end">
                        <div class="form-check mb-2">
                            <input
                                id="booth-type-is-active"
                                class="form-check-input"
                                type="checkbox"
                                name="isActive"
                                value="1"
                                <%= isChecked(formValues.isActive) ? 'checked' : '' %>
                            />
                            <label class="form-check-label" for="booth-type-is-active">
                                Active and available for market setup
                            </label>
                        </div>
                    </div>
                    <div class="col-12">
                        <button class="btn btn-primary" type="submit">
                            <%= mode === 'create' ? 'Create Booth Type' : 'Save Booth Type' %>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
