<%
    const pageData = marketOpsApplicationReviewPageData || {}
    const detail = pageData.applicationDetail || {}
    const application = detail.application || {}
    const vendorBusiness = detail.vendorBusiness || {}
    const marketGroup = detail.marketGroup || {}
    const selectionDecisionCards = Array.isArray(pageData.selectionDecisionCards) ? pageData.selectionDecisionCards : []
%>

<div class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-4">
    <div>
        <a class="text-decoration-none small d-inline-block mb-2" href="/market-ops/applications">Back to Applications</a>
        <h1 class="h3 mb-2">Application #<%= application.vendorApplicationId || '' %></h1>
        <p class="text-body-secondary mb-0">
            Review the vendor submission and decide each selected market independently.
        </p>
    </div>
    <span class="badge text-bg-light border text-uppercase"><%= application.status || 'draft' %></span>
</div>

<%- await include('../../partials/market-ops-flash.ejs', { marketOpsFlash: pageData.flash }) %>

<section class="row g-4 mb-4">
    <div class="col-12 col-xxl-8">
        <div class="card">
            <div class="card-header">
                <h2 class="h5 mb-1">Application Context</h2>
                <p class="text-body-secondary small mb-0">The parent application and vendor record driving the market-level decisions below.</p>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Vendor</dt>
                    <dd class="col-sm-9"><%= vendorBusiness.businessName || 'Vendor Business' %></dd>
                    <dt class="col-sm-3">Market Group</dt>
                    <dd class="col-sm-9"><%= marketGroup.groupName || 'Market Group' %></dd>
                    <dt class="col-sm-3">Application Key</dt>
                    <dd class="col-sm-9"><%= application.applicationKey || '—' %></dd>
                    <dt class="col-sm-3">Fee Snapshot</dt>
                    <dd class="col-sm-9"><%= application.feeModeSnapshot || 'none' %> · $<%= ((application.feeTotalCents || 0) / 100).toFixed(2) %></dd>
                </dl>
            </div>
        </div>
    </div>
</section>

<section class="d-flex flex-column gap-4">
    <% selectionDecisionCards.forEach((selectionCard) => { %>
        <%
            const selection = selectionCard.selection || {}
            const market = selection.market || {}
            const boothPreferences = Array.isArray(selection.boothPreferences) ? selection.boothPreferences : []
            const boothOfferingOptions = Array.isArray(selectionCard.boothOfferingOptions) ? selectionCard.boothOfferingOptions : []
            const formValues = selectionCard.formValues || {}
        %>
        <div class="card">
            <div class="card-header">
                <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-2">
                    <div>
                        <h2 class="h5 mb-1"><%= market.marketName || `Market #${selection.marketId}` %></h2>
                        <div class="small text-body-secondary">
                            Requested booths: <%= selection.requestedBoothQuantity %>
                            <% if (selection.willingToVolunteer === 1) { %> · Willing to volunteer<% } %>
                        </div>
                    </div>
                    <span class="badge text-bg-light border text-uppercase"><%= selection.selectionStatus || 'requested' %></span>
                </div>
            </div>
            <div class="card-body">
                <% if (boothPreferences.length > 0) { %>
                    <div class="mb-3">
                        <div class="small text-body-secondary mb-2">Booth Preferences</div>
                        <div class="d-flex flex-wrap gap-2">
                            <% boothPreferences.forEach((preference) => { %>
                                <span class="badge text-bg-light border">
                                    #<%= preference.preferenceRank %>
                                    <% if (preference.marketBoothOffering) { %>
                                        · Booth <%= preference.marketBoothOffering.boothNumber %>
                                    <% } %>
                                </span>
                            <% }) %>
                        </div>
                    </div>
                <% } %>

                <div class="row g-3 mb-4">
                    <div class="col-12 col-xl-6">
                        <form action="/market-ops/applications/<%= application.vendorApplicationId %>/selections/<%= selection.applicationMarketSelectionId %>/approve" method="post" class="d-flex flex-column gap-3 border rounded p-3 h-100">
                            <input type="hidden" name="_csrf" value="<%= ws_req.csrfToken %>" />
                            <div class="fw-semibold">Approve</div>
                            <div>
                                <label class="form-label" for="assigned-offering-<%= selection.applicationMarketSelectionId %>">Assigned Booth Offering</label>
                                <select id="assigned-offering-<%= selection.applicationMarketSelectionId %>" class="form-select" name="assignedMarketBoothOfferingId" required>
                                    <option value="">Choose a booth</option>
                                    <% boothOfferingOptions.forEach((option) => { %>
                                        <option
                                            value="<%= option.marketBoothOfferingId %>"
                                            <%= formValues.assignedMarketBoothOfferingId === String(option.marketBoothOfferingId) ? 'selected' : '' %>
                                        >
                                            Booth <%= option.boothNumber %> · <%= option.priceLabel %>
                                        </option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="row g-3">
                                <div class="col-12 col-md-6">
                                    <label class="form-label" for="assigned-quantity-<%= selection.applicationMarketSelectionId %>">Assigned Quantity</label>
                                    <input id="assigned-quantity-<%= selection.applicationMarketSelectionId %>" class="form-control" type="number" min="1" name="assignedBoothQuantity" value="<%= formValues.assignedBoothQuantity || '1' %>" required />
                                </div>
                                <div class="col-12 col-md-6">
                                    <label class="form-label" for="booth-fee-total-<%= selection.applicationMarketSelectionId %>">Booth Fee Total (USD)</label>
                                    <input id="booth-fee-total-<%= selection.applicationMarketSelectionId %>" class="form-control" type="text" name="boothFeeTotalDollars" value="<%= formValues.boothFeeTotalDollars || '0.00' %>" required />
                                </div>
                            </div>
                            <div>
                                <label class="form-label" for="approve-notes-<%= selection.applicationMarketSelectionId %>">Decision Notes</label>
                                <textarea id="approve-notes-<%= selection.applicationMarketSelectionId %>" class="form-control" rows="3" name="decisionNotes"><%= formValues.decisionNotes || '' %></textarea>
                            </div>
                            <button class="btn btn-success" type="submit">Approve Selection</button>
                        </form>
                    </div>

                    <div class="col-12 col-xl-6">
                        <div class="d-flex flex-column gap-3 h-100">
                            <form action="/market-ops/applications/<%= application.vendorApplicationId %>/selections/<%= selection.applicationMarketSelectionId %>/waitlist" method="post" class="border rounded p-3 d-flex flex-column gap-3">
                                <input type="hidden" name="_csrf" value="<%= ws_req.csrfToken %>" />
                                <div class="fw-semibold">Waitlist</div>
                                <textarea class="form-control" rows="3" name="decisionNotes" placeholder="Optional decision notes"><%= selection.decisionNotes || '' %></textarea>
                                <button class="btn btn-outline-secondary" type="submit">Waitlist Selection</button>
                            </form>

                            <form action="/market-ops/applications/<%= application.vendorApplicationId %>/selections/<%= selection.applicationMarketSelectionId %>/reject" method="post" class="border rounded p-3 d-flex flex-column gap-3">
                                <input type="hidden" name="_csrf" value="<%= ws_req.csrfToken %>" />
                                <div class="fw-semibold">Reject</div>
                                <textarea class="form-control" rows="3" name="decisionNotes" placeholder="Optional decision notes"><%= selection.decisionNotes || '' %></textarea>
                                <button class="btn btn-outline-danger" type="submit">Reject Selection</button>
                            </form>

                            <form action="/market-ops/applications/<%= application.vendorApplicationId %>/selections/<%= selection.applicationMarketSelectionId %>/withdraw" method="post" class="border rounded p-3 d-flex flex-column gap-3">
                                <input type="hidden" name="_csrf" value="<%= ws_req.csrfToken %>" />
                                <div class="fw-semibold">Withdraw</div>
                                <textarea class="form-control" rows="3" name="decisionNotes" placeholder="Optional decision notes"><%= selection.decisionNotes || '' %></textarea>
                                <button class="btn btn-outline-dark" type="submit">Withdraw Selection</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    <% }) %>
</section>
