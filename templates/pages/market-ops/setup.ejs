<%
    const pageData = marketOpsSetupPageData || {
        locations: [],
        boothTypes: [],
        productCategories: []
    }
    const activeSection =
        typeof marketOpsSetupActiveSection === 'string' && marketOpsSetupActiveSection
            ? marketOpsSetupActiveSection
            : 'locations'
%>

<link rel="stylesheet" href="/plugin-assets/ws_plugin_market_ops/styles/market-ops.css" />

<div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 m-0">Setup</h1>
        <p class="text-body-secondary mb-0">
            Maintain the reusable reference data that powers many markets over a long period of time.
        </p>
    </div>
</div>

<%- await include('../../partials/market-ops-flash.ejs', { marketOpsFlash }) %>

<section
    class="card"
    id="admin-plugins-discover-page"
    data-admin-plugins-discover-active-tab="<%= activeSection %>"
>
    <div class="card-header">
        <h2 class="h5 mb-1">Reference Data</h2>
        <p class="text-body-secondary mb-0">
            Keep these records clean and stable so markets, vendors, and later workflows can reuse them confidently.
        </p>
    </div>
    <div class="card-body">
        <div
            class="admin-plugins-discover-nav mb-4"
            role="tablist"
            aria-label="Market Ops setup section"
        >
            <button
                class="admin-plugins-discover-tab <%= activeSection === 'locations' ? 'active' : '' %>"
                id="marketOpsSetupTabLocations"
                type="button"
                role="tab"
                aria-selected="<%= activeSection === 'locations' ? 'true' : 'false' %>"
                aria-controls="marketOpsSetupPaneLocations"
                data-admin-plugins-discover-tab="locations"
            >
                Locations
            </button>
            <button
                class="admin-plugins-discover-tab <%= activeSection === 'booth_types' ? 'active' : '' %>"
                id="marketOpsSetupTabBoothTypes"
                type="button"
                role="tab"
                aria-selected="<%= activeSection === 'booth_types' ? 'true' : 'false' %>"
                aria-controls="marketOpsSetupPaneBoothTypes"
                data-admin-plugins-discover-tab="booth_types"
            >
                Booth Types
            </button>
            <button
                class="admin-plugins-discover-tab <%= activeSection === 'product_categories' ? 'active' : '' %>"
                id="marketOpsSetupTabProductCategories"
                type="button"
                role="tab"
                aria-selected="<%= activeSection === 'product_categories' ? 'true' : 'false' %>"
                aria-controls="marketOpsSetupPaneProductCategories"
                data-admin-plugins-discover-tab="product_categories"
            >
                Product Categories
            </button>
        </div>

        <div class="admin-plugins-discover-pane-wrap">
            <section
                class="admin-plugins-discover-pane <%= activeSection === 'locations' ? 'admin-plugins-discover-pane-active' : '' %>"
                id="marketOpsSetupPaneLocations"
                role="tabpanel"
                aria-labelledby="marketOpsSetupTabLocations"
                data-admin-plugins-discover-pane="locations"
                <%= activeSection === 'locations' ? '' : 'hidden' %>
            >
                <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
                    <div>
                        <h3 class="h5 mb-1">Locations</h3>
                        <p class="text-body-secondary mb-0">
                            Reusable venue records live here so market groups and dated markets can keep pointing at clean shared data.
                        </p>
                    </div>
                    <div class="d-flex gap-2 flex-wrap">
                        <a class="btn btn-primary" href="/market-ops/locations/create">Add Location</a>
                    </div>
                </div>

                <% if (pageData.locations.length === 0) { %>
                    <div class="admin-plugins-discover-empty-card">
                        <div class="admin-plugins-discover-empty-card-icon">
                            <i class="bi-geo-alt" aria-hidden="true"></i>
                        </div>
                        <div>
                            <h4 class="h5 mb-1">No locations yet</h4>
                            <p class="text-body-secondary mb-3">
                                Add the venues and layouts your markets can reuse across seasons and schedules.
                            </p>
                            <a class="btn btn-primary" href="/market-ops/locations/create">Create First Location</a>
                        </div>
                    </div>
                <% } else { %>
                    <div class="row g-3">
                        <% for (const location of pageData.locations) { %>
                            <div class="col-12 col-lg-6">
                                <a
                                    class="admin-plugins-discover-plugin-card-link text-decoration-none"
                                    href="/market-ops/locations/<%= location.locationId %>"
                                >
                                    <article class="admin-plugins-discover-plugin-card h-100">
                                        <div class="admin-plugins-discover-plugin-card-header">
                                            <div class="admin-plugins-discover-plugin-card-icon">
                                                <i class="bi-geo-alt-fill" aria-hidden="true"></i>
                                            </div>
                                            <div class="d-flex flex-wrap align-items-center gap-2">
                                                <h4 class="h5 mb-0 admin-plugins-discover-plugin-card-title">
                                                    <%= location.locationName %>
                                                </h4>
                                                <% if (location.isActive !== 1) { %>
                                                    <span class="badge text-bg-secondary">Inactive</span>
                                                <% } %>
                                            </div>
                                        </div>
                                        <% if (location.addressLine1 || location.city || location.stateCode || location.postalCode) { %>
                                            <div class="text-body-secondary">
                                                <%= [location.addressLine1, location.city, location.stateCode, location.postalCode].filter(Boolean).join(', ') %>
                                            </div>
                                        <% } else { %>
                                            <div class="text-body-secondary">Open the record to add address and venue notes.</div>
                                        <% } %>
                                    </article>
                                </a>
                            </div>
                        <% } %>
                    </div>
                <% } %>
            </section>

            <section
                class="admin-plugins-discover-pane <%= activeSection === 'booth_types' ? 'admin-plugins-discover-pane-active' : '' %>"
                id="marketOpsSetupPaneBoothTypes"
                role="tabpanel"
                aria-labelledby="marketOpsSetupTabBoothTypes"
                data-admin-plugins-discover-pane="booth_types"
                <%= activeSection === 'booth_types' ? '' : 'hidden' %>
            >
                <div class="d-flex flex-column gap-4">
                    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
                        <div>
                            <h3 class="h5 mb-1">Booth Types</h3>
                            <p class="text-body-secondary mb-0">
                                Define the reusable booth formats individual markets can later offer and assign.
                            </p>
                        </div>
                        <div class="d-flex gap-2 flex-wrap">
                            <a class="btn btn-primary" href="/market-ops/booth-types/create">Add Booth Type</a>
                        </div>
                    </div>

                    <% if (pageData.boothTypes.length === 0) { %>
                        <div class="admin-plugins-discover-empty-card">
                            <div class="admin-plugins-discover-empty-card-icon">
                                <i class="bi-grid-3x3-gap-fill" aria-hidden="true"></i>
                            </div>
                            <div>
                                <h4 class="h5 mb-1">No booth types yet</h4>
                                <p class="text-body-secondary mb-3">
                                    Create the reusable booth formats you want markets to choose from later.
                                </p>
                                <a class="btn btn-primary" href="/market-ops/booth-types/create">Create First Booth Type</a>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="row g-3">
                            <% for (const boothType of pageData.boothTypes) { %>
                                <div class="col-12 col-lg-6">
                                    <a
                                        class="admin-plugins-discover-plugin-card-link text-decoration-none"
                                        href="/market-ops/booth-types/<%= boothType.boothTypeId %>"
                                    >
                                        <article class="admin-plugins-discover-plugin-card h-100">
                                            <div class="admin-plugins-discover-plugin-card-header">
                                                <div class="admin-plugins-discover-plugin-card-icon">
                                                    <i class="bi-grid-3x3-gap-fill" aria-hidden="true"></i>
                                                </div>
                                                <div class="d-flex flex-wrap align-items-center gap-2">
                                                    <h4 class="h5 mb-0 admin-plugins-discover-plugin-card-title">
                                                        <%= boothType.label %>
                                                    </h4>
                                                    <% if (boothType.isActive !== 1) { %>
                                                        <span class="badge text-bg-secondary">Inactive</span>
                                                    <% } %>
                                                </div>
                                            </div>
                                            <p class="text-body-secondary mb-0">
                                                <%= boothType.description || 'Reusable booth format for later market-level offerings.' %>
                                            </p>
                                        </article>
                                    </a>
                                </div>
                            <% } %>
                        </div>
                    <% } %>
                </div>
            </section>

            <section
                class="admin-plugins-discover-pane <%= activeSection === 'product_categories' ? 'admin-plugins-discover-pane-active' : '' %>"
                id="marketOpsSetupPaneProductCategories"
                role="tabpanel"
                aria-labelledby="marketOpsSetupTabProductCategories"
                data-admin-plugins-discover-pane="product_categories"
                <%= activeSection === 'product_categories' ? '' : 'hidden' %>
            >
                <div class="d-flex flex-column gap-4">
                    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
                        <div>
                            <h3 class="h5 mb-1">Product Categories</h3>
                            <p class="text-body-secondary mb-0">
                                Maintain the reusable category library vendors can use to describe what they sell.
                            </p>
                        </div>
                        <div class="d-flex gap-2 flex-wrap">
                            <a class="btn btn-primary" href="/market-ops/product-categories/create">Add Product Category</a>
                        </div>
                    </div>

                    <% if (pageData.productCategories.length === 0) { %>
                        <div class="admin-plugins-discover-empty-card">
                            <div class="admin-plugins-discover-empty-card-icon">
                                <i class="bi-tags-fill" aria-hidden="true"></i>
                            </div>
                            <div>
                                <h4 class="h5 mb-1">No product categories yet</h4>
                                <p class="text-body-secondary mb-3">
                                    Create the reusable categories vendors can choose from when building their profiles.
                                </p>
                                <a class="btn btn-primary" href="/market-ops/product-categories/create">Create First Product Category</a>
                            </div>
                        </div>
                    <% } else { %>
                        <form
                            action="/market-ops/product-categories/reorder"
                            method="post"
                            class="market-ops-product-category-reorder-form"
                            data-market-ops-product-category-form
                        >
                            <input type="hidden" name="_csrf" value="<%= ws_req.csrfToken %>" />
                            <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
                                <p class="text-body-secondary mb-0">
                                    Drag categories into place or use the arrow buttons, then save the new order.
                                </p>
                                <button
                                    class="btn btn-outline-primary"
                                    type="submit"
                                    data-market-ops-product-category-save
                                    disabled
                                >
                                    Save Order
                                </button>
                            </div>
                            <div
                                class="d-flex flex-column gap-3"
                                data-market-ops-product-category-list
                            >
                                <% for (const productCategory of pageData.productCategories) { %>
                                    <article
                                        class="admin-plugins-discover-plugin-card market-ops-sortable-card"
                                        draggable="true"
                                        data-market-ops-product-category-item
                                        data-vendor-product-category-id="<%= productCategory.vendorProductCategoryId %>"
                                    >
                                        <div class="d-flex align-items-center justify-content-between gap-3 flex-nowrap">
                                            <div class="d-flex align-items-center gap-3 flex-grow-1 min-w-0">
                                                <button
                                                    class="btn btn-outline-secondary market-ops-sortable-handle"
                                                    type="button"
                                                    aria-label="Drag to reorder <%= productCategory.label %>"
                                                    title="Drag to reorder"
                                                    data-market-ops-product-category-handle
                                                >
                                                    <i class="bi-grip-vertical" aria-hidden="true"></i>
                                                </button>
                                                <div class="flex-grow-1 min-w-0 market-ops-sortable-copy">
                                                    <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                                        <h4 class="h5 mb-0 admin-plugins-discover-plugin-card-title">
                                                            <a
                                                                class="text-decoration-none text-reset"
                                                                href="/market-ops/product-categories/<%= productCategory.vendorProductCategoryId %>"
                                                            >
                                                                <%= productCategory.label %>
                                                            </a>
                                                        </h4>
                                                        <% if (productCategory.isActive !== 1) { %>
                                                            <span class="badge text-bg-secondary">Inactive</span>
                                                        <% } %>
                                                    </div>
                                                    <p class="text-body-secondary mb-0 market-ops-sortable-description">
                                                        <%= productCategory.description || 'Reusable product category for vendor profiles and later market workflows.' %>
                                                    </p>
                                                </div>
                                            </div>
                                            <div class="d-flex align-items-center gap-2 flex-shrink-0 flex-nowrap market-ops-sortable-actions">
                                                <button
                                                    class="btn btn-outline-secondary btn-sm d-none d-md-inline-flex"
                                                    type="button"
                                                    aria-label="Move <%= productCategory.label %> up"
                                                    data-market-ops-product-category-move="up"
                                                >
                                                    <i class="bi-arrow-up" aria-hidden="true"></i>
                                                </button>
                                                <button
                                                    class="btn btn-outline-secondary btn-sm d-none d-md-inline-flex"
                                                    type="button"
                                                    aria-label="Move <%= productCategory.label %> down"
                                                    data-market-ops-product-category-move="down"
                                                >
                                                    <i class="bi-arrow-down" aria-hidden="true"></i>
                                                </button>
                                                <a
                                                    class="btn btn-outline-primary btn-sm"
                                                    href="/market-ops/product-categories/<%= productCategory.vendorProductCategoryId %>"
                                                >
                                                    Edit
                                                </a>
                                            </div>
                                        </div>
                                    </article>
                                <% } %>
                            </div>
                            <div data-market-ops-product-category-order-inputs></div>
                        </form>
                    <% } %>
                </div>
            </section>
        </div>
    </div>
</section>

<script defer src="/scripts/admin-plugins-discover.js"></script>
<script defer src="/plugin-assets/ws_plugin_market_ops/scripts/product-category-ordering.js"></script>
