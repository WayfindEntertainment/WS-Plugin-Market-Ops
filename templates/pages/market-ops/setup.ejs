<%
    const pageData = marketOpsSetupPageData || {
        locations: [],
        boothTypes: []
    }
    const formValues = marketOpsBoothTypeFormValues || {}
    const helpers = marketOpsHelpers || {}
    const isChecked = typeof helpers.isCheckedValue === 'function' ? helpers.isCheckedValue : (() => false)
%>

<div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 m-0">Setup</h1>
        <p class="text-body-secondary mb-0">
            Maintain the low-frequency reference data that gets reused across many markets.
        </p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-outline-primary" href="/market-ops/locations">Manage Locations</a>
        <a class="btn btn-primary" href="/market-ops/locations/create">New Location</a>
    </div>
</div>

<%- await include('../../partials/market-ops-flash.ejs', { marketOpsFlash }) %>

<section class="row g-4">
    <div class="col-12 col-xl-5">
        <div class="card mb-4">
            <div class="card-header">
                <h2 class="h5 mb-1">Locations</h2>
                <p class="text-body-secondary small mb-0">
                    Reusable market venues live here so groups and dated markets can keep pointing to clean records.
                </p>
            </div>
            <div class="card-body p-0">
                <% if (pageData.locations.length === 0) { %>
                    <div class="p-4 text-body-secondary">
                        No locations yet. Add the venues and layouts your markets can reuse.
                    </div>
                <% } else { %>
                    <div class="list-group list-group-flush">
                        <% for (const location of pageData.locations) { %>
                            <a
                                class="list-group-item list-group-item-action d-flex flex-column gap-1"
                                href="/market-ops/locations/<%= location.locationId %>"
                            >
                                <div class="fw-semibold"><%= location.locationName %></div>
                                <div class="small text-body-secondary">
                                    <%= location.slug %>
                                    <% if (location.city || location.stateCode) { %>
                                        · <%= [location.city, location.stateCode].filter(Boolean).join(', ') %>
                                    <% } %>
                                </div>
                            </a>
                        <% } %>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-7">
        <div class="card mb-4">
            <div class="card-header">
                <h2 class="h5 mb-1">Create Booth Type</h2>
                <p class="text-body-secondary small mb-0">
                    Define the reusable booth formats you can later assign to individual markets.
                </p>
            </div>
            <div class="card-body">
                <form action="/market-ops/booth-types" method="post" class="row g-3">
                    <input type="hidden" name="_csrf" value="<%= ws_req.csrfToken %>" />
                    <div class="col-12 col-md-6">
                        <label class="form-label" for="setup-booth-type-label">Label</label>
                        <input
                            id="setup-booth-type-label"
                            class="form-control"
                            type="text"
                            name="label"
                            value="<%= formValues.label || '' %>"
                            required
                        />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label" for="setup-booth-type-slug">Slug</label>
                        <input
                            id="setup-booth-type-slug"
                            class="form-control"
                            type="text"
                            name="slug"
                            value="<%= formValues.slug || '' %>"
                            required
                        />
                    </div>
                    <div class="col-12">
                        <label class="form-label" for="setup-booth-type-description">Description</label>
                        <textarea
                            id="setup-booth-type-description"
                            class="form-control"
                            rows="3"
                            name="description"
                        ><%= formValues.description || '' %></textarea>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label" for="setup-booth-type-sort-order">Sort Order</label>
                        <input
                            id="setup-booth-type-sort-order"
                            class="form-control"
                            type="number"
                            min="0"
                            name="sortOrder"
                            value="<%= formValues.sortOrder || '0' %>"
                            required
                        />
                    </div>
                    <div class="col-12 col-md-6 d-flex align-items-end">
                        <div class="form-check mb-2">
                            <input
                                id="setup-booth-type-is-active"
                                class="form-check-input"
                                type="checkbox"
                                name="isActive"
                                value="1"
                                <%= isChecked(formValues.isActive) ? 'checked' : '' %>
                            />
                            <label class="form-check-label" for="setup-booth-type-is-active">
                                Active and available
                            </label>
                        </div>
                    </div>
                    <div class="col-12">
                        <button class="btn btn-primary" type="submit">Create Booth Type</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h2 class="h5 mb-1">Booth Type Library</h2>
                <p class="text-body-secondary small mb-0">
                    Update reusable booth labels and availability without opening a specific market.
                </p>
            </div>
            <div class="card-body">
                <% if (pageData.boothTypes.length === 0) { %>
                    <p class="text-body-secondary mb-0">No booth types yet.</p>
                <% } else { %>
                    <div class="d-flex flex-column gap-3">
                        <% for (const boothType of pageData.boothTypes) { %>
                            <form
                                class="border rounded p-3"
                                action="/market-ops/booth-types/<%= boothType.boothTypeId %>"
                                method="post"
                            >
                                <input type="hidden" name="_csrf" value="<%= ws_req.csrfToken %>" />
                                <div class="row g-3">
                                    <div class="col-12 col-md-6">
                                        <label class="form-label">Label</label>
                                        <input class="form-control" type="text" name="label" value="<%= boothType.label %>" required />
                                    </div>
                                    <div class="col-12 col-md-6">
                                        <label class="form-label">Slug</label>
                                        <input class="form-control" type="text" name="slug" value="<%= boothType.slug %>" required />
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">Description</label>
                                        <textarea class="form-control" rows="2" name="description"><%= boothType.description || '' %></textarea>
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <label class="form-label">Sort Order</label>
                                        <input class="form-control" type="number" min="0" name="sortOrder" value="<%= boothType.sortOrder %>" required />
                                    </div>
                                    <div class="col-12 col-md-4 d-flex align-items-end">
                                        <div class="form-check mb-2">
                                            <input
                                                id="booth-type-active-<%= boothType.boothTypeId %>"
                                                class="form-check-input"
                                                type="checkbox"
                                                name="isActive"
                                                value="1"
                                                <%= boothType.isActive === 1 ? 'checked' : '' %>
                                            />
                                            <label class="form-check-label" for="booth-type-active-<%= boothType.boothTypeId %>">
                                                Active
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-4 d-flex align-items-end">
                                        <button class="btn btn-outline-primary w-100" type="submit">Save</button>
                                    </div>
                                </div>
                            </form>
                        <% } %>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</section>
