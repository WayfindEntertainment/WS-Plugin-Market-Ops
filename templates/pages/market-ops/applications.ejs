<%
    const pageData = marketOpsApplicationsPageData || {}
    const applicationCards = Array.isArray(pageData.applicationCards) ? pageData.applicationCards : []
%>

<div class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 mb-2">Applications</h1>
        <p class="text-body-secondary mb-0">
            Review submitted market-group applications and drill into each selected market for booth decisions.
        </p>
    </div>
</div>

<%- await include('../../partials/market-ops-flash.ejs', { marketOpsFlash: pageData.flash }) %>

<div class="row g-3">
    <% if (applicationCards.length === 0) { %>
        <div class="col-12">
            <div class="card">
                <div class="card-body text-body-secondary">
                    No vendor applications have been created yet.
                </div>
            </div>
        </div>
    <% } %>
    <% applicationCards.forEach((applicationCard) => { %>
        <div class="col-12 col-xxl-8">
            <a class="card text-decoration-none text-reset h-100" href="/market-ops/applications/<%= applicationCard.vendorApplicationId %>">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between gap-3 mb-2">
                        <h2 class="h5 mb-0"><%= applicationCard.vendorBusinessName %></h2>
                        <span class="badge text-bg-light border text-uppercase"><%= applicationCard.status %></span>
                    </div>
                    <div class="text-body-secondary mb-2"><%= applicationCard.marketGroupName %></div>
                    <div class="row g-2 small text-body-secondary">
                        <div class="col-sm-6">Selections: <%= applicationCard.selectionCount %></div>
                        <div class="col-sm-6">Application Fee: <%= applicationCard.feeTotalLabel %></div>
                        <div class="col-sm-6">Requested: <%= applicationCard.requestedCount %></div>
                        <div class="col-sm-6">Approved: <%= applicationCard.approvedCount %></div>
                    </div>
                </div>
            </a>
        </div>
    <% }) %>
</div>
